import javax.persistence.*;

@Entity
@Table(name = "products")
public class Product {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private int id;
    private String name;
    private double price;

    // Constructors, Getters, Setters
    public Product(String name, double price) {
        this.name = name;
        this.price = price;
    }
}
